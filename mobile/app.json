{
  "expo": {
    "name": "Dashboard",
    "slug": "vend88-dashboard-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vend88mobile",
    "jsEngine": "hermes",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vend88.dashboard",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDisplayName": "Dashboard"
      }
    },
    "android": {
      "package": "com.vend88.dashboard",
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#181E38"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 230,
          "resizeMode": "contain",
          "backgroundColor": "#181e38",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#181e38"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true,
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/19929edd-50b1-492e-babf-140d6dcaab95"
    },
    "runtimeVersion": "1.0.0",
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "vend88s-organization",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "19929edd-50b1-492e-babf-140d6dcaab95"
      }
    }
  }
}
